[Unit]
Description=OffiMesh Celery Beat
After=network.target redis-server.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/offimesh
EnvironmentFile=/opt/offimesh/.env
ExecStart=/opt/offimesh/.venv/bin/uv run celery -A app.workers.celery_app beat --loglevel=info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
