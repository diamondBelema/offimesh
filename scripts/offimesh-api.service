[Unit]
Description=OffiMesh FastAPI
After=network.target redis-server.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/offimesh
EnvironmentFile=/opt/offimesh/.env
ExecStart=/opt/offimesh/.venv/bin/uv run uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 4
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
