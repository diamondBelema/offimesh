# OffiMesh Backend - Environment Configuration Template
# Copy this file to .env and fill in the values

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=OffiMesh
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/offimesh

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ============================================
# JWT SETTINGS (RS256)
# ============================================
# Generate keys with:
# ssh-keygen -t rsa -b 4096 -m PEM -f jwt-private.pem
# openssl rsa -in jwt-private.pem -pubout -outform PEM -out jwt-public.pem
# Then paste the contents here (as single line with \n for newlines)

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ============================================
# NOMBA API CONFIGURATION (Sandbox)
# ============================================
NOMBA_ENVIRONMENT=sandbox
NOMBA_BASE_URL=https://sandbox.api.nomba.com/v1

# Parent Account ID (required for all API calls)
NOMBA_ACCOUNT_ID=f666ef9b-888e-4799-85ce-acb505b28023

# Sub-account ID (for transaction scoping)
NOMBA_SUBACCOUNT_ID=4c28f5f6-afa1-4a01-9c2c-84597e451b0b

# OAuth Credentials (from Nomba Dashboard)
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=

# Webhook Secret (for signature verification)
NOMBA_WEBHOOK_SECRET=

# ============================================
# OFFLINE TOKEN SETTINGS
# ============================================
OFFLINE_TOKEN_DEFAULT_LIMIT_KOBO=50000
OFFLINE_TOKEN_MAX_LIMIT_KOBO=500000
OFFLINE_TOKEN_TTL_HOURS=48
OFFLINE_TOKEN_GRACE_HOURS=2

# ============================================
# TRANSACTION LIMITS
# ============================================
MAX_SYNC_BATCH_SIZE=100
MAX_TRANSACTION_AMOUNT_KOBO=5000000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# CORS
# ============================================
CORS_ORIGINS=*

# ============================================
# SMS GATEWAY (Optional - for OTP)
# ============================================
# Options: termii | africastalking | mock
SMS_PROVIDER=mock

# Termii: https://termii.com
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_SENDER_ID=OffiMesh

# Africa's Talking (use when SMS_PROVIDER=africastalking):
# https://africastalking.com - sign up, get API key and username
# SMS_GATEWAY_API_KEY is reused as the AT apiKey
SMS_GATEWAY_USERNAME=sandbox

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# For authentication, real-time notifications, and database

# Supabase project URL (e.g., https://xyzcompany.supabase.co)
SUPABASE_URL=

# Supabase anonymous key (public, safe for client-side)
# Found in Project Settings > API > Project API keys
SUPABASE_ANON_KEY=

# Supabase service role key (secret, server-side only)
# Found in Project Settings > API > Project API keys
# WARNING: This key bypasses RLS - keep it secret!
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT secret for token verification
# Found in Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=
